{
  "name": "agent-tasks",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@analogjs/platform:vite",
      "defaultConfiguration": "production",
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "sourcemap": false,
          "mode": "production"
        }
      },
      "outputs": [
        "{options.outputPath}",
        "{workspaceRoot}/dist/agent-tasks/.nitro",
        "{workspaceRoot}/dist/agent-tasks/ssr",
        "{workspaceRoot}/dist/agent-tasks/analog"
      ],
      "options": {
        "main": "agent-tasks/src/main.ts",
        "configFile": "agent-tasks/vite.config.ts",
        "outputPath": "dist/agent-tasks/client",
        "tsConfig": "agent-tasks/tsconfig.app.json"
      }
    },
    "serve": {
      "executor": "@analogjs/platform:vite-dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "agent-tasks:build",
        "port": 4200
      },
      "configurations": {
        "development": {
          "buildTarget": "agent-tasks:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "agent-tasks:build:production"
        }
      }
    },
    "test": {
      "executor": "@analogjs/vitest-angular:test",
      "outputs": [
        "{projectRoot}/coverage"
      ]
    }
  },
  "tags": [],
  "sourceRoot": "./agent-tasks/src"
}
